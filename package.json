{
  "name": "qris-eventhub",
  "version": "1.0.0",
  "main": "api/index.js",
  "description": "Backend server for Android Notification Listener app",
  "scripts": {
    "express:start": "node api/index.js",
    "express:dev": "nodemon api/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "cf:dev": "wrangler dev",
    "cf:deploy": "wrangler deploy",
    "cf:db:create": "wrangler d1 create notification-listener-db",
    "cf:db:init": "wrangler d1 execute notification-listener-db --file=./schema.sql",
    "cf:tail": "wrangler tail"
  },
  "keywords": [
    "notification",
    "android",
    "webhook",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.10",
    "vitest": "^3.2.4",
    "wrangler": "^4.34.0"
  }
}
