# ─── Backend (Express / server.js) ──────────────────────────────────────────
PORT=3000
API_KEY=your-secret-api-key

# Database (Express mode only — Cloudflare uses D1, Vercel uses Turso)
DB_PATH=./notifications.db

# CORS
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Cloudflare Worker (src/worker.js) ──────────────────────────────────────
# Set via `wrangler secret put` or in wrangler.toml [vars]
# API_KEY=your-secret-api-key
# CALLBACK_SECRET=generate-a-long-random-string-here

# ─── Vercel (api/index.js) ──────────────────────────────────────────────────
# Set in Vercel Dashboard → Settings → Environment Variables
# API_KEY=your-secret-api-key
# CALLBACK_SECRET=generate-a-long-random-string-here

# Turso database (required for Vercel deployment)
# Create at https://turso.tech → `turso db create qris-eventhub`
TURSO_DATABASE_URL=libsql://your-db-name-username.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token
