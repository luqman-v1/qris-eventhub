# ─── Backend (Express / server.js) ──────────────────────────────────────────
PORT=3000
API_KEY=your-secret-api-key

# Database (Express mode only — Cloudflare uses D1)
DB_PATH=./notifications.db

# CORS
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Cloudflare Worker (src/worker.js) ──────────────────────────────────────
# Set these as secrets via `wrangler secret put` or in wrangler.toml [vars]

# API key for authenticating incoming requests (same as above)
# API_KEY=your-secret-api-key

# SHA-256 signature secret for callback webhook payloads
# Used to sign X-QRIS-Signature header when firing payment callbacks
# Must match the secret configured on the merchant/receiver side
# CALLBACK_SECRET=generate-a-long-random-string-here
